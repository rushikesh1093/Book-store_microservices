# ============================================================
# Analytics Microservice — environment
# Copy to .env and fill in values. Shares the Django DB & Redis.
# ============================================================

# Service
DEBUG=True

# Shared PostgreSQL (same value as the Django backend DATABASE_URL).
# Format: postgresql://<user>:<pass>@<host>/<db>?sslmode=require&channel_binding=require
DATABASE_URL=

# Shared Redis (same value as the Django backend REDIS_URL).
# Format: redis://:<password>@<host>:<port>   or   redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Toggles (set false to disable in tests / CI)
SCHEDULER_ENABLED=True
REDIS_CONSUMER_ENABLED=True

# Where generated report files are written
REPORTS_DIR=generated_reports

# CORS (comma-separated). Use ["*"] / * for any origin in dev.
# CORS_ORIGINS=http://localhost:3000

# Business rules
# CHURN_RISK_DAYS=90
# SLOW_MOVER_DAYS=90
