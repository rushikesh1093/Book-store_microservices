# ============================================================
# Analytics Microservice — environment
# Copy to .env and fill in values. Shares the Django DB & Redis.
# ============================================================

# Service
DEBUG=False

# Shared PostgreSQL (same value as the Django backend DATABASE_URL).
# Format: postgresql://<user>:<pass>@<host>/<db>?sslmode=require&channel_binding=require
DATABASE_URL=

# Shared Redis — OPTIONAL. The service runs fully without Redis.
# Only set these if you want live event ingestion AND have a reachable Redis.
REDIS_CONSUMER_ENABLED=False
# REDIS_URL=redis://localhost:6379

# Scheduler (ETL jobs) — DB-only, safe to leave enabled.
SCHEDULER_ENABLED=True

# Where generated report files are written
REPORTS_DIR=generated_reports

# Port (Render/Railway inject this automatically)
# PORT=8001
